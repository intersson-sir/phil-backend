# Backend Environment Variables Template
# Copy this file to .env and fill in your actual values

# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-base64-32
ALLOWED_HOSTS=api.yourdomain.com,yourdomain.com,your-ip-address

# Database Configuration
DATABASE_URL=postgresql://username:password@db:5432/dbname
DATABASE_PASSWORD=your-db-password-here

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# CORS Settings
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Celery Tasks Settings
ENABLE_URL_CHECK_TASK=False
URL_CHECK_INTERVAL_HOURS=24

# Logging
DJANGO_LOG_LEVEL=INFO
